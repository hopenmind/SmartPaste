<Window x:Class="SmartPaste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartPaste Settings" Height="580" Width="560"
        Icon="assets/icon-192.png"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Background="#1E40AF" Padding="15,12">
            <StackPanel Orientation="Horizontal">
                <Image Source="assets/icon-192.png" Width="32" Height="32" Margin="0,0,10,0"/>
                <TextBlock Text="SmartPaste" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text=" v1.0" FontSize="14" Foreground="#93C5FD" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="10" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" BorderThickness="1,1,1,0" BorderBrush="#9CA3AF" CornerRadius="4,4,0,0" Padding="15,8" Margin="0,0,2,0">
                                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#1E40AF"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter TargetName="Border" Property="Background" Value="#E5E7EB"/>
                                        <Setter Property="Foreground" Value="#1F2937"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- TAB 1: Shortcuts -->
            <TabItem Header="Shortcuts">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" Foreground="#111827">Keyboard Shortcuts</TextBlock>
                        <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,0,0,10" TextWrapping="Wrap">Click on any shortcut value to edit it. Use format: Ctrl+Shift+V, Alt+F1, etc.</TextBlock>

                        <Border BorderBrush="#9CA3AF" BorderThickness="1" CornerRadius="6" Background="#F3F4F6">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Smart Paste (Primary)" Margin="0,0,0,8" VerticalAlignment="Center" Foreground="#111827"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtSP1" Margin="0,0,0,8" Padding="4,2" FontFamily="Consolas" TextChanged="TxtShortcut_TextChanged"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Smart Paste (Space)" Margin="0,0,0,8" VerticalAlignment="Center" Foreground="#111827"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtSP2" Margin="0,0,0,8" Padding="4,2" FontFamily="Consolas" TextChanged="TxtShortcut_TextChanged"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Smart Paste (Normal)" Margin="0,0,0,8" VerticalAlignment="Center" Foreground="#111827"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtSP3" Margin="0,0,0,8" Padding="4,2" FontFamily="Consolas" TextChanged="TxtShortcut_TextChanged"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Smart Copy" Margin="0,0,0,8" VerticalAlignment="Center" Foreground="#111827"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtSC" Margin="0,0,0,8" Padding="4,2" FontFamily="Consolas" TextChanged="TxtShortcut_TextChanged"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Case Converter" Margin="0,0,0,8" VerticalAlignment="Center" Foreground="#111827"/>
                                <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtCC" Margin="0,0,0,8" Padding="4,2" FontFamily="Consolas" TextChanged="TxtShortcut_TextChanged"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Always On Top" Margin="0,0,0,0" VerticalAlignment="Center" Foreground="#111827"/>
                                <TextBox Grid.Row="5" Grid.Column="1" x:Name="TxtAOT" Margin="0,0,0,0" Padding="4,2" FontFamily="Consolas" TextChanged="TxtShortcut_TextChanged"/>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="TxtShortcutError" Foreground="#DC2626" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: Telework -->
            <TabItem Header="Telework">
                <ScrollViewer Padding="15" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5" Foreground="#111827">Core Simulation</TextBlock>
                        <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,0,0,10" TextWrapping="Wrap">These options are mixed together to create a realistic human typing pattern.</TextBlock>

                        <CheckBox x:Name="ChkTeleVariable" Content="Variable Rhythm (random delay between keystrokes)" Margin="0,0,0,4" Foreground="#111827" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                        <CheckBox x:Name="ChkTeleMicroPauses" Content="Micro-Pauses (occasional &quot;thinking&quot; pauses)" Margin="0,0,0,4" Foreground="#111827" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                        <CheckBox x:Name="ChkTeleFlowBursts" Content="Flow Bursts (sudden rapid typing acceleration)" Margin="0,0,0,4" Foreground="#111827" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                        <CheckBox x:Name="ChkTeleBreathing" Content="Breathing Pauses (periodic longer rests)" Margin="0,0,0,4" Foreground="#111827" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                        <CheckBox x:Name="ChkTeleEndOfLine" Content="End-of-Line Pause (pause after Enter/newline)" Margin="0,0,0,15" Foreground="#111827" Checked="Tele_Changed" Unchecked="Tele_Changed"/>

                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5" Foreground="#111827">Realistic Errors</TextBlock>
                        <CheckBox x:Name="ChkTeleTypos" Content="Realistic Typos (wrong letter → Backspace → retype)" Margin="0,0,0,4" Foreground="#111827" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                        <CheckBox x:Name="ChkTeleCapsErrors" Content="Random Caps Errors (occasional wrong capitalization)" Margin="0,0,0,4" Foreground="#111827" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                        <CheckBox x:Name="ChkTeleDoubleKey" Content="Double Key Strokes (accidental double-tap)" Margin="0,0,0,4" Foreground="#111827" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                        <CheckBox x:Name="ChkTeleCursorNav" Content="Cursor Navigation (arrow key corrections)" Margin="0,0,0,4" Foreground="#111827" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                        <CheckBox x:Name="ChkTeleAutoCorrect" Content="Auto-Correct Mistakes (fixes typos automatically)" Margin="0,0,0,15" Foreground="#111827" Checked="Tele_Changed" Unchecked="Tele_Changed"/>

                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5" Foreground="#111827">Timing</TextBlock>
                        <TextBlock FontSize="12" Foreground="#374151" Margin="0,0,0,3">Base delay: <Run x:Name="TxtTeleDelay">100</Run> ms</TextBlock>
                        <Slider x:Name="SldTeleDelay" Minimum="20" Maximum="300" Value="100" TickFrequency="10" IsSnapToTickEnabled="True" Margin="0,0,0,10" ValueChanged="SldTeleDelay_ValueChanged"/>

                        <TextBlock FontSize="12" Foreground="#374151" Margin="0,0,0,3">Word chunk size: <Run x:Name="TxtTeleChunk">5</Run> characters</TextBlock>
                        <Slider x:Name="SldTeleChunk" Minimum="2" Maximum="20" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,10" ValueChanged="SldTeleChunk_ValueChanged"/>

                        <TextBlock FontSize="12" Foreground="#374151" Margin="0,0,0,3">Breathing interval: every <Run x:Name="TxtTeleBreath">15</Run> characters</TextBlock>
                        <Slider x:Name="SldTeleBreath" Minimum="5" Maximum="50" Value="15" TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,0,0,5" ValueChanged="SldTeleBreath_ValueChanged"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 3: Functions -->
            <TabItem Header="Functions">
                <ScrollViewer Padding="15" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" Foreground="#111827">Enable / Disable Features</TextBlock>
                        <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,0,0,15" TextWrapping="Wrap">Toggle individual features on or off. Disabled features will not respond to their shortcuts.</TextBlock>

                        <CheckBox x:Name="ChkEnableSP" Content="Smart Paste (list pasting modes)" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#111827" Checked="Func_Changed" Unchecked="Func_Changed"/>
                        <CheckBox x:Name="ChkEnableSC" Content="Smart Copy (web content capture)" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#111827" Checked="Func_Changed" Unchecked="Func_Changed"/>
                        <CheckBox x:Name="ChkEnableCC" Content="Case Converter (text case cycling)" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#111827" Checked="Func_Changed" Unchecked="Func_Changed"/>
                        <CheckBox x:Name="ChkEnableAOT" Content="Always On Top (window pinning)" Margin="0,0,0,20" FontWeight="SemiBold" Foreground="#111827" Checked="Func_Changed" Unchecked="Func_Changed"/>

                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" Foreground="#111827">Typing Speed</TextBlock>
                        <TextBlock x:Name="TxtSpeedLabel" FontSize="13" Foreground="#374151" Margin="0,0,0,5">Base delay: 30 ms</TextBlock>
                        <Slider x:Name="SldSpeed" Minimum="0" Maximum="200" Value="30" TickFrequency="10" IsSnapToTickEnabled="True" Margin="0,0,0,20" ValueChanged="SldSpeed_ValueChanged"/>

                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" Foreground="#111827">Startup</TextBlock>
                        <CheckBox x:Name="ChkStartMinimized" Content="Start minimized to system tray" Margin="0,0,0,8" Foreground="#111827" Checked="ChkStartMinimized_Checked" Unchecked="ChkStartMinimized_Checked"/>
                        <CheckBox x:Name="ChkAutoStart" Content="Auto-start with Windows (copies to AppData)" Margin="0,0,0,15" Foreground="#111827" Checked="ChkAutoStart_Checked" Unchecked="ChkAutoStart_Checked"/>

                        <Button Content="Reset to Defaults" HorizontalAlignment="Right" Padding="15,6" Margin="0,10,0,0"
                                Click="BtnReset_Click" Background="#E5E7EB" BorderBrush="#9CA3AF" Foreground="#111827"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 4: About -->
            <TabItem Header="About">
                <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
                    <StackPanel HorizontalAlignment="Center" MaxWidth="400">
                        <Image Source="assets/icon-192.png" Width="96" Height="96" Margin="0,0,0,15"/>
                        <TextBlock Text="SmartPaste" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2" Foreground="#111827"/>
                        <TextBlock Text="Version 1.0.0" FontSize="14" Foreground="#4B5563" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,15" Foreground="#1F2937">
                            A lightweight Windows utility that transforms how you paste, copy, and manage text.
                            Features smart list pasting with human simulation, case conversion, always-on-top pinning, and intelligent web content copying with Base64 image embedding.
                        </TextBlock>

                        <Border BorderBrush="#9CA3AF" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15" Background="#F3F4F6">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#111827">Features</TextBlock>
                                <BulletDecorator><BulletDecorator.Bullet><Ellipse Width="6" Height="6" Fill="#1E40AF" Margin="0,0,6,0"/></BulletDecorator.Bullet><TextBlock TextWrapping="Wrap" Foreground="#1F2937">Smart Paste — 3 modes with auto-splitting</TextBlock></BulletDecorator>
                                <BulletDecorator Margin="0,4,0,0"><BulletDecorator.Bullet><Ellipse Width="6" Height="6" Fill="#1E40AF" Margin="0,0,6,0"/></BulletDecorator.Bullet><TextBlock TextWrapping="Wrap" Foreground="#1F2937">Telework Mode — 10 realistic typing options</TextBlock></BulletDecorator>
                                <BulletDecorator Margin="0,4,0,0"><BulletDecorator.Bullet><Ellipse Width="6" Height="6" Fill="#1E40AF" Margin="0,0,6,0"/></BulletDecorator.Bullet><TextBlock TextWrapping="Wrap" Foreground="#1F2937">Smart Copy — Web math/images as Base64</TextBlock></BulletDecorator>
                                <BulletDecorator Margin="0,4,0,0"><BulletDecorator.Bullet><Ellipse Width="6" Height="6" Fill="#1E40AF" Margin="0,0,6,0"/></BulletDecorator.Bullet><TextBlock TextWrapping="Wrap" Foreground="#1F2937">Case Converter — Cycle text cases</TextBlock></BulletDecorator>
                                <BulletDecorator Margin="0,4,0,0"><BulletDecorator.Bullet><Ellipse Width="6" Height="6" Fill="#1E40AF" Margin="0,0,6,0"/></BulletDecorator.Bullet><TextBlock TextWrapping="Wrap" Foreground="#1F2937">Always On Top — Pin any window</TextBlock></BulletDecorator>
                                <BulletDecorator Margin="0,4,0,0"><BulletDecorator.Bullet><Ellipse Width="6" Height="6" Fill="#1E40AF" Margin="0,0,6,0"/></BulletDecorator.Bullet><TextBlock TextWrapping="Wrap" Foreground="#1F2937">Custom Shortcuts — Remap any hotkey</TextBlock></BulletDecorator>
                            </StackPanel>
                        </Border>

                        <TextBlock TextAlignment="Center" Margin="0,0,0,5" Foreground="#111827">
                            <Run FontWeight="SemiBold">Developed by</Run>
                            <LineBreak/>
                            <Run>Hope 'n Mind</Run>
                        </TextBlock>
                        <TextBlock TextAlignment="Center" Margin="0,0,0,15">
                            <Hyperlink NavigateUri="https://www.hopenmind.com" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#1E40AF">
                                www.hopenmind.com
                            </Hyperlink>
                        </TextBlock>

                        <Border BorderBrush="#9CA3AF" BorderThickness="1" CornerRadius="6" Padding="12" Background="#FEF2F2">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Foreground="#991B1B" Margin="0,0,0,5">License</TextBlock>
                                <TextBlock FontSize="12" Foreground="#7F1D1D" TextWrapping="Wrap">
                                    All Rights Reserved. This software is provided free of charge for personal, non-commercial use only.
                                    No right of exploitation, distribution, modification, or commercial use is granted without a prior written license agreement.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
