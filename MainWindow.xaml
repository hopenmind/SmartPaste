<Window x:Class="SmartPaste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartPaste Settings" Height="520" Width="520"
        Icon="assets/icon-192.png"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Background="#2563EB" Padding="15,12">
            <StackPanel Orientation="Horizontal">
                <Image Source="assets/icon-192.png" Width="32" Height="32" Margin="0,0,10,0"/>
                <TextBlock Text="SmartPaste" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text=" v1.0" FontSize="14" Foreground="#BFDBFE" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="10" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" BorderThickness="1,1,1,0" BorderBrush="#ddd" CornerRadius="4,4,0,0" Padding="15,8" Margin="0,0,2,0">
                                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#2563EB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter TargetName="Border" Property="Background" Value="#F3F4F6"/>
                                        <Setter Property="Foreground" Value="#374151"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- TAB 1: Shortcuts -->
            <TabItem Header="⌨ Shortcuts">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10">Smart Paste (Paste List)</TextBlock>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Margin="0,0,0,15" Background="#F9FAFB">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" FontFamily="Consolas" FontWeight="SemiBold" Foreground="#2563EB" Margin="0,0,0,8">Ctrl+Win+V</TextBlock>
                                <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8">Normal Mode — Types letter by letter</TextBlock>

                                <TextBlock Grid.Row="1" Grid.Column="0" FontFamily="Consolas" FontWeight="SemiBold" Foreground="#2563EB" Margin="0,0,0,8">Ctrl+Alt+V</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8">Word by word + SPACE — Splits on punctuation</TextBlock>

                                <TextBlock Grid.Row="2" Grid.Column="0" FontFamily="Consolas" FontWeight="SemiBold" Foreground="#2563EB" Margin="0,0,0,8">Ctrl+Shift+V</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8">Word by word + ENTER — One item per line</TextBlock>

                                <TextBlock Grid.Row="3" Grid.Column="0" FontFamily="Consolas" FontWeight="SemiBold" Foreground="#059669" Margin="0,0,0,0">+ Shift</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,0">Add Shift to any shortcut for <Run FontWeight="SemiBold">Human Simulation Mode</Run></TextBlock>
                            </Grid>
                        </Border>

                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10">Utilities</TextBlock>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Margin="0,0,0,15" Background="#F9FAFB">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" FontFamily="Consolas" FontWeight="SemiBold" Foreground="#7C3AED" Margin="0,0,0,8">Ctrl+Shift+C</TextBlock>
                                <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8">Smart Copy — Embeds web images &amp; math as Base64</TextBlock>

                                <TextBlock Grid.Row="1" Grid.Column="0" FontFamily="Consolas" FontWeight="SemiBold" Foreground="#7C3AED" Margin="0,0,0,8">Ctrl+Win+C</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8">Case Converter — Cycles lower → UPPER → Title → aLtErNaTe</TextBlock>

                                <TextBlock Grid.Row="2" Grid.Column="0" FontFamily="Consolas" FontWeight="SemiBold" Foreground="#7C3AED" Margin="0,0,0,0">Ctrl+Alt+T</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,0">Always On Top — Pins/unpins the active window</TextBlock>
                            </Grid>
                        </Border>

                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10">Smart Splitting</TextBlock>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Background="#F9FAFB">
                            <TextBlock Margin="12" TextWrapping="Wrap" Foreground="#4B5563">
                                SmartPaste automatically detects and splits your copied text by any of these separators:
                                <LineBreak/>
                                <Border Background="#E5E7EB" CornerRadius="3" Padding="4,2" Margin="0,2,0,0" HorizontalAlignment="Left">
                                    <TextBlock FontFamily="Consolas" FontSize="12">  ,  ;  :  .  /  \  |  •  ·  (newline)  (tab)  </TextBlock>
                                </Border>
                                <LineBreak/><LineBreak/>
                                If none are found, it falls back to splitting by spaces.
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: Settings -->
            <TabItem Header="⚙ Settings">
                <ScrollViewer Padding="15" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Typing Speed -->
                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5">Typing Speed</TextBlock>
                        <TextBlock x:Name="TxtSpeedLabel" FontSize="12" Foreground="#6B7280" Margin="0,0,0,5">Base delay: 30 ms</TextBlock>
                        <Slider x:Name="SldSpeed" Minimum="0" Maximum="200" Value="30" TickFrequency="10" IsSnapToTickEnabled="True" 
                                Margin="0,0,0,15" ValueChanged="SldSpeed_ValueChanged"/>

                        <!-- Human Simulation -->
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15" Background="#FFFBEB">
                            <StackPanel>
                                <CheckBox x:Name="ChkHumanSim" Content="Enable Human Simulation (Telework Mode)" FontWeight="SemiBold" 
                                          Checked="ChkHumanSim_Checked" Unchecked="ChkHumanSim_Checked" Margin="0,0,0,5"/>
                                <TextBlock FontSize="12" Foreground="#92400E" TextWrapping="Wrap">
                                    Simulates natural typing rhythm: variable speed, micro-pauses, "flow" bursts, and optional typos with backspace.
                                    <LineBreak/>Makes pasting indistinguishable from a real human typing.
                                </TextBlock>
                                <CheckBox x:Name="ChkTypos" Content="Include realistic typos (backspace &amp; retype)" Margin="15,8,0,0"
                                          Checked="ChkTypos_Checked" Unchecked="ChkTypos_Checked"/>
                            </StackPanel>
                        </Border>

                        <!-- Startup Options -->
                        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10">Startup</TextBlock>
                        <CheckBox x:Name="ChkStartMinimized" Content="Start minimized to system tray" Margin="0,0,0,8" 
                                  Checked="ChkStartMinimized_Checked" Unchecked="ChkStartMinimized_Checked"/>
                        <CheckBox x:Name="ChkAutoStart" Content="Auto-start with Windows (copies to AppData)" Margin="0,0,0,15" 
                                  Checked="ChkAutoStart_Checked" Unchecked="ChkAutoStart_Checked"/>

                        <!-- Reset Button -->
                        <Button Content="Reset to Defaults" HorizontalAlignment="Right" Padding="15,6" Margin="0,10,0,0"
                                Click="BtnReset_Click" Background="#F3F4F6" BorderBrush="#D1D5DB"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 3: About -->
            <TabItem Header="ℹ About">
                <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
                    <StackPanel HorizontalAlignment="Center" MaxWidth="400">
                        <!-- Logo -->
                        <Image Source="assets/icon-192.png" Width="96" Height="96" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="SmartPaste" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="Version 1.0.0" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,15" Foreground="#374151">
                            A lightweight Windows utility that transforms how you paste, copy, and manage text.
                            Features smart list pasting, case conversion, always-on-top pinning, and intelligent web content copying with Base64 image embedding.
                        </TextBlock>

                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15" Background="#F9FAFB">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Margin="0,0,0,5">Features</TextBlock>
                                <BulletDecorator><BulletDecorator.Bullet><Ellipse Width="6" Height="6" Fill="#2563EB" Margin="0,0,6,0"/></BulletDecorator.Bullet><TextBlock TextWrapping="Wrap">Smart Paste — 3 modes with auto-splitting</TextBlock></BulletDecorator>
                                <BulletDecorator Margin="0,4,0,0"><BulletDecorator.Bullet><Ellipse Width="6" Height="6" Fill="#2563EB" Margin="0,0,6,0"/></BulletDecorator.Bullet><TextBlock TextWrapping="Wrap">Human Simulation — Realistic typing rhythm</TextBlock></BulletDecorator>
                                <BulletDecorator Margin="0,4,0,0"><BulletDecorator.Bullet><Ellipse Width="6" Height="6" Fill="#2563EB" Margin="0,0,6,0"/></BulletDecorator.Bullet><TextBlock TextWrapping="Wrap">Smart Copy — Web math/images as Base64</TextBlock></BulletDecorator>
                                <BulletDecorator Margin="0,4,0,0"><BulletDecorator.Bullet><Ellipse Width="6" Height="6" Fill="#2563EB" Margin="0,0,6,0"/></BulletDecorator.Bullet><TextBlock TextWrapping="Wrap">Case Converter — Cycle text cases</TextBlock></BulletDecorator>
                                <BulletDecorator Margin="0,4,0,0"><BulletDecorator.Bullet><Ellipse Width="6" Height="6" Fill="#2563EB" Margin="0,0,6,0"/></BulletDecorator.Bullet><TextBlock TextWrapping="Wrap">Always On Top — Pin any window</TextBlock></BulletDecorator>
                            </StackPanel>
                        </Border>

                        <TextBlock TextAlignment="Center" Margin="0,0,0,5">
                            <Run FontWeight="SemiBold">Developed by</Run>
                            <LineBreak/>
                            <Run>Hope 'n Mind</Run>
                        </TextBlock>
                        <TextBlock TextAlignment="Center" Margin="0,0,0,15">
                            <Hyperlink NavigateUri="https://www.hopenmind.com" RequestNavigate="Hyperlink_RequestNavigate">
                                www.hopenmind.com
                            </Hyperlink>
                        </TextBlock>

                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="12" Background="#FEF2F2">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Foreground="#991B1B" Margin="0,0,0,5">License</TextBlock>
                                <TextBlock FontSize="12" Foreground="#7F1D1D" TextWrapping="Wrap">
                                    All Rights Reserved. This software is provided free of charge for personal, non-commercial use only.
                                    No right of exploitation, distribution, modification, or commercial use is granted without a prior written license agreement.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
