<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================================
         SmartPaste Design System

         Palette:  Slate greys + Blue brand accent
         Spacing:  4, 8, 12, 16, 24, 32, 48
         Type:     Segoe UI Variable / Segoe UI
         Corners:  6px cards, 4px inputs, 8px modals
         Shadows:  3-tier elevation (sm, md, lg)
         ================================================================ -->

    <!-- ── Greys (Slate, slightly cool-tinted) ──────────────────────── -->
    <Color x:Key="Grey950">#0F172A</Color>
    <Color x:Key="Grey900">#1E293B</Color>
    <Color x:Key="Grey800">#334155</Color>
    <Color x:Key="Grey700">#475569</Color>
    <Color x:Key="Grey600">#64748B</Color>
    <Color x:Key="Grey500">#94A3B8</Color>
    <Color x:Key="Grey400">#CBD5E1</Color>
    <Color x:Key="Grey300">#E2E8F0</Color>
    <Color x:Key="Grey200">#F1F5F9</Color>
    <Color x:Key="Grey100">#F8FAFC</Color>

    <!-- ── Brand Blue ───────────────────────────────────────────────── -->
    <Color x:Key="Blue900">#1E3A8A</Color>
    <Color x:Key="Blue700">#1D4ED8</Color>
    <Color x:Key="Blue600">#2563EB</Color>
    <Color x:Key="Blue500">#3B82F6</Color>
    <Color x:Key="Blue400">#60A5FA</Color>
    <Color x:Key="Blue200">#BFDBFE</Color>
    <Color x:Key="Blue100">#DBEAFE</Color>
    <Color x:Key="Blue50">#EFF6FF</Color>

    <!-- ── Semantic ─────────────────────────────────────────────────── -->
    <Color x:Key="Red600">#DC2626</Color>
    <Color x:Key="Red100">#FEE2E2</Color>
    <Color x:Key="Red900">#7F1D1D</Color>
    <Color x:Key="Green600">#16A34A</Color>

    <!-- ── Brushes ──────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource Grey950}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource Grey700}"/>
    <SolidColorBrush x:Key="TextTertiary" Color="{StaticResource Grey600}"/>
    <SolidColorBrush x:Key="TextMuted" Color="{StaticResource Grey500}"/>

    <SolidColorBrush x:Key="BgPrimary" Color="White"/>
    <SolidColorBrush x:Key="BgSecondary" Color="{StaticResource Grey100}"/>
    <SolidColorBrush x:Key="BgTertiary" Color="{StaticResource Grey200}"/>
    <SolidColorBrush x:Key="BgCard" Color="White"/>

    <SolidColorBrush x:Key="BorderDefault" Color="{StaticResource Grey300}"/>
    <SolidColorBrush x:Key="BorderSubtle" Color="{StaticResource Grey200}"/>

    <SolidColorBrush x:Key="AccentPrimary" Color="{StaticResource Blue600}"/>
    <SolidColorBrush x:Key="AccentDark" Color="{StaticResource Blue900}"/>
    <SolidColorBrush x:Key="AccentLight" Color="{StaticResource Blue100}"/>
    <SolidColorBrush x:Key="AccentSoft" Color="{StaticResource Blue50}"/>
    <SolidColorBrush x:Key="AccentText" Color="{StaticResource Blue700}"/>

    <SolidColorBrush x:Key="DangerBg" Color="{StaticResource Red100}"/>
    <SolidColorBrush x:Key="DangerText" Color="{StaticResource Red900}"/>
    <SolidColorBrush x:Key="DangerBorder" Color="{StaticResource Red600}"/>

    <!-- ── Shadows ──────────────────────────────────────────────────── -->
    <DropShadowEffect x:Key="ShadowSm" BlurRadius="4" ShadowDepth="1" Direction="270" Opacity="0.08" Color="Black"/>
    <DropShadowEffect x:Key="ShadowMd" BlurRadius="12" ShadowDepth="3" Direction="270" Opacity="0.10" Color="Black"/>

    <!-- ── Typography ───────────────────────────────────────────────── -->
    <FontFamily x:Key="FontUI">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="FontMono">Cascadia Code, Consolas, monospace</FontFamily>

    <!-- ── Base Window/Panel ────────────────────────────────────────── -->
    <Style x:Key="WindowBase" TargetType="Window">
        <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Background" Value="{StaticResource BgSecondary}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>

    <!-- ── Section Title (small caps label, de-emphasized) ──────────── -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ── Heading (actual emphasis) ────────────────────────────────── -->
    <Style x:Key="Heading" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- ── Body text ────────────────────────────────────────────────── -->
    <Style x:Key="Body" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="20"/>
    </Style>

    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="16"/>
    </Style>

    <!-- ── Card container ───────────────────────────────────────────── -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgCard}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect" Value="{StaticResource ShadowSm}"/>
    </Style>

    <!-- ── Accent Card (like the brand box) ─────────────────────────── -->
    <Style x:Key="AccentCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentLight}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- ── Danger Card ──────────────────────────────────────────────── -->
    <Style x:Key="DangerCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DangerBg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DangerBg}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- ── Tab Item ─────────────────────────────────────────────────── -->
    <Style x:Key="ModernTab" TargetType="TabItem">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder" Padding="16,10" Margin="0,0,4,0"
                            Background="Transparent" CornerRadius="6,6,0,0"
                            BorderThickness="0,0,0,2" BorderBrush="Transparent">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource BgCard}"/>
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentPrimary}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource BgTertiary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── CheckBox ─────────────────────────────────────────────────── -->
    <Style x:Key="FeatureToggle" TargetType="CheckBox">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <Style x:Key="OptionToggle" TargetType="CheckBox">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <!-- ── Button (Primary) ─────────────────────────────────────────── -->
    <Style x:Key="BtnPrimary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentPrimary}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background">
                                <Setter.Value><SolidColorBrush Color="{StaticResource Blue700}"/></Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Button (Secondary / Ghost) ───────────────────────────────── -->
    <Style x:Key="BtnSecondary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgTertiary}"/>
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource TextMuted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Shortcut Input Border ────────────────────────────────────── -->
    <Style x:Key="ShortcutInput" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- ── Slider ───────────────────────────────────────────────────── -->
    <Style x:Key="ValueSlider" TargetType="Slider">
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="IsSnapToTickEnabled" Value="True"/>
    </Style>

</ResourceDictionary>
