<Window x:Class="SmartPaste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SmartPaste"
        Title="SmartPaste" Height="660" Width="560"
        MinHeight="520" MinWidth="480"
        Style="{StaticResource WindowBase}"
        Icon="/assets/icon-192.png"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────── -->
        <Border Background="{StaticResource AccentDark}" Padding="20,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/assets/icon-192.png" Width="28" Height="28" Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="SmartPaste" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnLang" Content="EN" Style="{StaticResource BtnSecondary}"
                            Padding="8,4" FontSize="11" FontWeight="Bold" Margin="0,0,8,0"
                            Click="BtnLang_Click" Background="Transparent" BorderBrush="#5B7FC0" Foreground="White"/>
                    <TextBlock Text="v2.0" FontSize="11" Foreground="{StaticResource AccentLight}" VerticalAlignment="Center" Opacity="0.7"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Tab Control ────────────────────────────────────────── -->
        <TabControl Grid.Row="1" Margin="16,12,16,16" BorderThickness="0"
                    Background="Transparent" Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource ModernTab}"/>
            </TabControl.Resources>

            <!-- ══════════════ TAB 1: Shortcuts ══════════════ -->
            <TabItem Header="{DynamicResource TabShortcuts}">
                <ScrollViewer Padding="4,16,4,4" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- SMART PASTE -->
                        <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource HeadSmartPaste}"/>
                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource DescSmartPaste}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="Medium" Foreground="{StaticResource TextPrimary}" Text="{DynamicResource SP1Label}"/>
                                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource SP1Desc}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" x:Name="BorderSP1" Style="{StaticResource ShortcutInput}" Width="160" MouseDown="ShortcutBorder_MouseDown">
                                        <TextBlock x:Name="TxtSP1" FontFamily="{StaticResource FontMono}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                    </Border>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="Medium" Foreground="{StaticResource TextPrimary}" Text="{DynamicResource SP2Label}"/>
                                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource SP2Desc}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" x:Name="BorderSP2" Style="{StaticResource ShortcutInput}" Width="160" MouseDown="ShortcutBorder_MouseDown">
                                        <TextBlock x:Name="TxtSP2" FontFamily="{StaticResource FontMono}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                    </Border>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="Medium" Foreground="{StaticResource TextPrimary}" Text="{DynamicResource SP3Label}"/>
                                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource SP3Desc}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" x:Name="BorderSP3" Style="{StaticResource ShortcutInput}" Width="160" MouseDown="ShortcutBorder_MouseDown">
                                        <TextBlock x:Name="TxtSP3" FontFamily="{StaticResource FontMono}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                    </Border>
                                </Grid>
                                <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,0" Padding="0,8,0,0">
                                    <CheckBox x:Name="ChkOverrideV" Style="{StaticResource OptionToggle}" Margin="0"
                                              Content="{DynamicResource OverrideV}" Checked="Func_Changed" Unchecked="Func_Changed"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- SMART COPY -->
                        <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource HeadSmartCopy}"/>
                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource DescSmartCopy}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="Medium" Foreground="{StaticResource TextPrimary}" Text="{DynamicResource SCLabel}"/>
                                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource SCDesc}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" x:Name="BorderSC" Style="{StaticResource ShortcutInput}" Width="160" MouseDown="ShortcutBorder_MouseDown">
                                        <TextBlock x:Name="TxtSC" FontFamily="{StaticResource FontMono}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                    </Border>
                                </Grid>
                                <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,0" Padding="0,8,0,0">
                                    <CheckBox x:Name="ChkOverrideC" Style="{StaticResource OptionToggle}" Margin="0"
                                              Content="{DynamicResource OverrideC}" Checked="Func_Changed" Unchecked="Func_Changed"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- UTILITIES -->
                        <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource HeadUtilities}"/>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="Medium" Foreground="{StaticResource TextPrimary}" Text="{DynamicResource CCLabel}"/>
                                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource CCDesc}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" x:Name="BorderCC" Style="{StaticResource ShortcutInput}" Width="160" MouseDown="ShortcutBorder_MouseDown">
                                        <TextBlock x:Name="TxtCC" FontFamily="{StaticResource FontMono}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                    </Border>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="Medium" Foreground="{StaticResource TextPrimary}" Text="{DynamicResource AOTLabel}"/>
                                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource AOTDesc}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" x:Name="BorderAOT" Style="{StaticResource ShortcutInput}" Width="160" MouseDown="ShortcutBorder_MouseDown">
                                        <TextBlock x:Name="TxtAOT" FontFamily="{StaticResource FontMono}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                    </Border>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="Medium" Foreground="{StaticResource TextPrimary}" Text="{DynamicResource TeleLabel}"/>
                                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TeleDesc}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" x:Name="BorderTele" Style="{StaticResource ShortcutInput}" Width="160" MouseDown="ShortcutBorder_MouseDown">
                                        <TextBlock x:Name="TxtTele" FontFamily="{StaticResource FontMono}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="TxtShortcutError" Foreground="{StaticResource DangerBorder}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════ TAB 2: Telework ══════════════ -->
            <TabItem Header="{DynamicResource TabTelework}">
                <ScrollViewer Padding="4,16,4,4" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource AccentCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Heading}" Foreground="{StaticResource AccentText}" Text="{DynamicResource TeleIntroTitle}" Margin="0,0,0,4"/>
                                <TextBlock Style="{StaticResource Body}" Foreground="{StaticResource TextSecondary}" Text="{DynamicResource TeleIntroDesc}"/>
                            </StackPanel>
                        </Border>

                        <!-- Rhythm -->
                        <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource HeadRhythm}"/>
                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource DescRhythm}" Margin="0,0,0,8"/>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox x:Name="ChkTeleVariable" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleVariable}" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TeleVariableDesc}" Margin="24,0,0,8"/>
                                <CheckBox x:Name="ChkTeleMicroPauses" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleMicro}" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TeleMicroDesc}" Margin="24,0,0,8"/>
                                <CheckBox x:Name="ChkTeleFlowBursts" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleFlow}" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TeleFlowDesc}" Margin="24,0,0,8"/>
                                <CheckBox x:Name="ChkTeleBreathing" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleBreath}" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TeleBreathDesc}" Margin="24,0,0,8"/>
                                <CheckBox x:Name="ChkTeleEndOfLine" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleEOL}" Margin="0" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TeleEOLDesc}" Margin="24,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Mistakes -->
                        <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource HeadMistakes}"/>
                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource DescMistakes}" Margin="0,0,0,8"/>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox x:Name="ChkTeleTypos" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleTypo}" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TeleTypoDesc}" Margin="24,0,0,8"/>
                                <CheckBox x:Name="ChkTeleCapsErrors" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleCaps}" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TeleCapsDesc}" Margin="24,0,0,8"/>
                                <CheckBox x:Name="ChkTeleDoubleKey" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleDouble}" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TeleDoubleDesc}" Margin="24,0,0,8"/>
                                <CheckBox x:Name="ChkTeleCursorNav" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleCursor}" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TeleCursorDesc}" Margin="24,0,0,8"/>
                                <CheckBox x:Name="ChkTeleAutoCorrect" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleAuto}" Margin="0" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TeleAutoDesc}" Margin="24,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Timing -->
                        <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource HeadTiming}"/>
                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource DescTiming}" Margin="0,0,0,8"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Body}" Margin="0,0,0,4">Base delay: <Run x:Name="TxtTeleDelay" FontWeight="SemiBold">100</Run> ms</TextBlock>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TimingDelayHint}" Margin="0,0,0,4"/>
                                <Slider x:Name="SldTeleDelay" Style="{StaticResource ValueSlider}" Minimum="20" Maximum="300" Value="100" TickFrequency="10" ValueChanged="SldTeleDelay_ValueChanged"/>

                                <TextBlock Style="{StaticResource Body}" Margin="0,0,0,4">Word chunk: <Run x:Name="TxtTeleChunk" FontWeight="SemiBold">5</Run> chars</TextBlock>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TimingChunkHint}" Margin="0,0,0,4"/>
                                <Slider x:Name="SldTeleChunk" Style="{StaticResource ValueSlider}" Minimum="2" Maximum="20" Value="5" TickFrequency="1" ValueChanged="SldTeleChunk_ValueChanged"/>

                                <TextBlock Style="{StaticResource Body}" Margin="0,0,0,4">Breathing: <Run x:Name="TxtTeleBreath" FontWeight="SemiBold">15</Run> chars</TextBlock>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource TimingBreathHint}" Margin="0,0,0,4"/>
                                <Slider x:Name="SldTeleBreath" Style="{StaticResource ValueSlider}" Minimum="5" Maximum="50" Value="15" TickFrequency="5" Margin="0" ValueChanged="SldTeleBreath_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Launch command center -->
                        <Button Style="{StaticResource BtnPrimary}" Margin="0,24,0,0"
                                Content="{DynamicResource DashLaunch}" FontSize="14"
                                Padding="0,12" HorizontalAlignment="Stretch"
                                Click="BtnDashLaunch_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════ TAB 3: Options ══════════════ -->
            <TabItem Header="{DynamicResource TabOptions}">
                <ScrollViewer Padding="4,16,4,4" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource HeadFeatures}"/>
                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource DescFeatures}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox x:Name="ChkEnableSP" Style="{StaticResource FeatureToggle}" Content="{DynamicResource FeatSP}" Checked="Func_Changed" Unchecked="Func_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource FeatSPDesc}" Margin="24,0,0,12"/>
                                <CheckBox x:Name="ChkEnableSC" Style="{StaticResource FeatureToggle}" Content="{DynamicResource FeatSC}" Checked="Func_Changed" Unchecked="Func_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource FeatSCDesc}" Margin="24,0,0,12"/>
                                <CheckBox x:Name="ChkEnablePI" Style="{StaticResource FeatureToggle}" Content="{DynamicResource FeatPI}" Checked="Func_Changed" Unchecked="Func_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource FeatPIDesc}" Margin="24,0,0,12"/>
                                <CheckBox x:Name="ChkEnableCC" Style="{StaticResource FeatureToggle}" Content="{DynamicResource FeatCC}" Checked="Func_Changed" Unchecked="Func_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource FeatCCDesc}" Margin="24,0,0,12"/>
                                <CheckBox x:Name="ChkEnableAOT" Style="{StaticResource FeatureToggle}" Content="{DynamicResource FeatAOT}" Checked="Func_Changed" Unchecked="Func_Changed"/>
                                <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource FeatAOTDesc}" Margin="24,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource HeadSpeed}"/>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock x:Name="TxtSpeedLabel" Style="{StaticResource Body}">Base delay: <Run FontWeight="SemiBold">30</Run> ms</TextBlock>
                                <Slider x:Name="SldSpeed" Style="{StaticResource ValueSlider}" Minimum="0" Maximum="200" Value="30" TickFrequency="10" Margin="0" ValueChanged="SldSpeed_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource HeadStartup}"/>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox x:Name="ChkStartMinimized" Style="{StaticResource OptionToggle}" Content="{DynamicResource StartMinimized}" Checked="ChkStartMinimized_Checked" Unchecked="ChkStartMinimized_Checked"/>
                                <CheckBox x:Name="ChkAutoStart" Style="{StaticResource OptionToggle}" Content="{DynamicResource AutoStart}" Margin="0" Checked="ChkAutoStart_Checked" Unchecked="ChkAutoStart_Checked"/>
                            </StackPanel>
                        </Border>

                        <Button Content="{DynamicResource BtnReset}" Style="{StaticResource BtnSecondary}" HorizontalAlignment="Right" Click="BtnReset_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════ TAB 4: About ══════════════ -->
            <TabItem Header="{DynamicResource TabAbout}">
                <ScrollViewer Padding="4,16,4,4" VerticalScrollBarVisibility="Auto">
                    <StackPanel HorizontalAlignment="Center" MaxWidth="380">
                        <Image Source="/assets/icon-192.png" Width="80" Height="80" Margin="0,0,0,16" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="SmartPaste" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="Version 2.0.0" FontSize="12" Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                        <TextBlock Style="{StaticResource Body}" TextAlignment="Center" Text="{DynamicResource AboutDesc}" Margin="0,0,0,24"/>

                        <Border Style="{StaticResource AccentCard}" Margin="0,0,0,16">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource AccentText}" HorizontalAlignment="Center" Margin="0,0,0,4">Hope 'n Mind</TextBlock>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <Hyperlink NavigateUri="https://www.hopenmind.com" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{StaticResource AccentPrimary}">www.hopenmind.com</Hyperlink>
                                </TextBlock>
                                <TextBlock Style="{StaticResource Caption}" TextAlignment="Center" Text="{DynamicResource AboutTagline}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DangerCard}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Foreground="{StaticResource DangerText}" Text="{DynamicResource LicenseTitle}" Margin="0,0,0,4"/>
                                <TextBlock FontSize="11" Foreground="{StaticResource DangerText}" TextWrapping="Wrap" Opacity="0.8" Text="{DynamicResource LicenseText}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- ══════════════ DASHBOARD (fullscreen command center) ══════════════ -->
        <Grid x:Name="Dashboard" Grid.Row="1" Visibility="Collapsed" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Left panel -->
            <Grid Grid.Column="0" Margin="24,16,12,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="100"/>
                </Grid.RowDefinitions>

                <!-- Mode toggle -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="RbManual" Content="{DynamicResource DashManual}" GroupName="DashMode"
                                 IsChecked="True" Margin="0,0,16,0" FontWeight="SemiBold"
                                 Foreground="{StaticResource TextPrimary}" Click="DashMode_Click"/>
                    <RadioButton x:Name="RbAuto" Content="{DynamicResource DashAuto}" GroupName="DashMode"
                                 FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Click="DashMode_Click"/>
                </StackPanel>

                <!-- Manual mode: text input -->
                <Border Grid.Row="1" x:Name="PanelManual" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="{DynamicResource DashInput}" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="1" x:Name="TxtDashInput"
                                 AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="{StaticResource FontMono}" FontSize="13"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextPrimary}"/>
                    </Grid>
                </Border>

                <!-- Auto mode: sources + targets -->
                <Grid Grid.Row="1" x:Name="PanelAuto" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Sources -->
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="{DynamicResource DashSources}" Margin="0"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="+ File" Style="{StaticResource BtnSecondary}"
                                            Padding="8,2" FontSize="11" Margin="0,0,4,0" Click="BtnAddSourceFile_Click"/>
                                    <Button Content="+ URL" Style="{StaticResource BtnSecondary}"
                                            Padding="8,2" FontSize="11" Click="BtnAddSourceUrl_Click"/>
                                </StackPanel>
                            </Grid>
                            <ListBox Grid.Row="1" x:Name="LstSources" Background="Transparent"
                                     BorderThickness="0" FontFamily="{StaticResource FontMono}" FontSize="11"
                                     Foreground="{StaticResource TextSecondary}"
                                     KeyDown="LstSources_KeyDown"/>
                        </Grid>
                    </Border>

                    <!-- Targets -->
                    <Border Grid.Row="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="{DynamicResource DashTargets}" Margin="0"/>
                                <Button Content="+ App" Style="{StaticResource BtnSecondary}" HorizontalAlignment="Right"
                                        Padding="8,2" FontSize="11" Click="BtnAddTarget_Click"/>
                            </Grid>
                            <ListBox Grid.Row="1" x:Name="LstTargets" Background="Transparent"
                                     BorderThickness="0" FontFamily="{StaticResource FontMono}" FontSize="11"
                                     Foreground="{StaticResource TextSecondary}" MaxHeight="100"
                                     KeyDown="LstTargets_KeyDown"/>
                        </Grid>
                    </Border>

                    <!-- Auto options -->
                    <Border Grid.Row="4" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Body}" Margin="0,0,0,4">
                                Interval: <Run x:Name="TxtAutoMin" FontWeight="SemiBold">30</Run>s
                                — <Run x:Name="TxtAutoMax" FontWeight="SemiBold">120</Run>s
                            </TextBlock>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="SldAutoMin" Minimum="5" Maximum="300" Value="30"
                                        TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,0,4,0"
                                        ValueChanged="SldAutoInterval_Changed"/>
                                <Slider Grid.Column="1" x:Name="SldAutoMax" Minimum="5" Maximum="600" Value="120"
                                        TickFrequency="5" IsSnapToTickEnabled="True" Margin="4,0,0,0"
                                        ValueChanged="SldAutoInterval_Changed"/>
                            </Grid>
                            <CheckBox x:Name="ChkAutoLoop" Style="{StaticResource OptionToggle}"
                                      Content="{DynamicResource DashLoop}" IsChecked="True"/>
                            <CheckBox x:Name="ChkAutoClear" Style="{StaticResource OptionToggle}"
                                      Content="{DynamicResource DashClear}" Margin="0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Preview (shared) -->
                <TextBlock Grid.Row="2" Style="{StaticResource SectionTitle}" Text="{DynamicResource DashPreview}" Margin="0,12,0,8"/>
                <Border Grid.Row="3" Style="{StaticResource Card}" Background="{StaticResource BgTertiary}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtDashPreview" TextWrapping="Wrap"
                                   FontFamily="{StaticResource FontMono}" FontSize="12"
                                   Foreground="{StaticResource AccentPrimary}"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Right: Status + Quick settings -->
            <StackPanel Grid.Column="1" Margin="0,16,24,16">
                <!-- Status -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="STATUS"/>
                        <TextBlock x:Name="TxtDashStatus" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,8">IDLE</TextBlock>
                        <ProgressBar x:Name="PrgDash" Minimum="0" Maximum="100" Value="0"
                                     Height="6" Margin="0,0,0,8"
                                     Foreground="{StaticResource AccentPrimary}"
                                     Background="{StaticResource BgTertiary}"/>
                        <TextBlock x:Name="TxtDashChars" Style="{StaticResource Body}" Margin="0,0,0,4">0 / 0</TextBlock>
                        <TextBlock x:Name="TxtDashElapsed" Style="{StaticResource Caption}">00:00</TextBlock>
                    </StackPanel>
                </Border>

                <!-- Countdown -->
                <Border x:Name="DashCountdownPanel" Style="{StaticResource AccentCard}" Margin="0,0,0,16" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtDashCountdown" FontSize="48" FontWeight="Bold"
                                   Foreground="{StaticResource AccentText}" HorizontalAlignment="Center"/>
                        <TextBlock Style="{StaticResource Caption}" Text="{DynamicResource DashCountdownHint}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Quick settings -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="{DynamicResource DashQuickSettings}"/>
                        <CheckBox x:Name="ChkDashVariable" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleVariable}" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                        <CheckBox x:Name="ChkDashMicro" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleMicro}" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                        <CheckBox x:Name="ChkDashFlow" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleFlow}" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                        <CheckBox x:Name="ChkDashTypos" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleTypo}" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                        <CheckBox x:Name="ChkDashBreath" Style="{StaticResource OptionToggle}" Content="{DynamicResource TeleBreath}" Margin="0" Checked="Tele_Changed" Unchecked="Tele_Changed"/>
                    </StackPanel>
                </Border>

                <!-- Delay slider -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Body}" Margin="0,0,0,4">Delay: <Run x:Name="TxtDashDelay" FontWeight="SemiBold">100</Run> ms</TextBlock>
                        <Slider x:Name="SldDashDelay" Minimum="20" Maximum="300" Value="100"
                                TickFrequency="10" IsSnapToTickEnabled="True" Margin="0"
                                ValueChanged="SldDashDelay_ValueChanged"/>
                    </StackPanel>
                </Border>

                <!-- Scheduler with analog clock -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Style="{StaticResource SectionTitle}" Text="{DynamicResource DashScheduler}" Margin="0"/>
                            <CheckBox x:Name="ChkScheduler" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      Content="{DynamicResource DashSchedulerOn}"
                                      Checked="ChkScheduler_Changed" Unchecked="ChkScheduler_Changed"/>
                        </Grid>
                        <TextBlock x:Name="TxtScheduleStatus" Style="{StaticResource Caption}" Margin="0,0,0,4"/>

                        <!-- Analog clock picker -->
                        <local:ScheduleClock x:Name="ClockPicker" HorizontalAlignment="Center"/>

                        <!-- Week day toggles (compact) -->
                        <ItemsControl x:Name="WeekGrid" Margin="0,4,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                            CornerRadius="3" Padding="6,3" Margin="2">
                                        <CheckBox IsChecked="{Binding Enabled}" Content="{Binding DayLabel}"
                                                  FontSize="11" Foreground="{StaticResource TextTertiary}"
                                                  Checked="ScheduleDay_Changed" Unchecked="ScheduleDay_Changed"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Bottom: Controls -->
            <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,0"
                    Padding="24,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnDashStart" Style="{StaticResource BtnPrimary}"
                            Content="{DynamicResource DashStart}" Padding="32,10" Margin="0,0,8,0"
                            FontSize="14" Click="BtnDashStart_Click"/>
                    <Button x:Name="BtnDashPause" Style="{StaticResource BtnSecondary}"
                            Content="{DynamicResource DashPause}" Padding="24,10" Margin="0,0,8,0"
                            IsEnabled="False" Click="BtnDashPause_Click"/>
                    <Button x:Name="BtnDashStop" Style="{StaticResource BtnSecondary}"
                            Content="{DynamicResource DashStop}" Padding="24,10" Margin="0,0,32,0"
                            IsEnabled="False" Click="BtnDashStop_Click"/>
                    <Button Style="{StaticResource BtnSecondary}"
                            Content="{DynamicResource DashExit}" Padding="24,10"
                            Click="BtnDashExit_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
