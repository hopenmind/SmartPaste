<UserControl x:Class="SmartPaste.ScheduleClock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="260" Height="320">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="260"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Clock face -->
        <Canvas x:Name="Dial" Width="260" Height="260" ClipToBounds="True"
                Background="Transparent"
                MouseLeftButtonDown="Dial_MouseDown"
                MouseMove="Dial_MouseMove"
                MouseLeftButtonUp="Dial_MouseUp"/>

        <!-- Digital readout -->
        <Border Grid.Row="1" Background="#1A1A20" CornerRadius="4" Margin="20,8,20,0" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtWorkAM" FontFamily="Cascadia Code,Consolas"
                               FontSize="13" Foreground="#60A5FA" HorizontalAlignment="Center"/>
                    <TextBlock Text="work" FontSize="9" Foreground="#555" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0">
                    <TextBlock x:Name="TxtLunch" FontFamily="Cascadia Code,Consolas"
                               FontSize="13" Foreground="#666" HorizontalAlignment="Center"/>
                    <TextBlock Text="lunch" FontSize="9" Foreground="#444" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtWorkPM" FontFamily="Cascadia Code,Consolas"
                               FontSize="13" Foreground="#60A5FA" HorizontalAlignment="Center"/>
                    <TextBlock Text="work" FontSize="9" Foreground="#555" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
